@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cuenta Bloqueada - CEPLAN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #f5f5f5;
            /* Mantenemos tu mismo fondo */
            background-image: url('/img/inicioSesion.png');
            background-repeat: no-repeat;
            background-position: bottom left;
            background-size: contain;
            font-family: 'Segoe UI', sans-serif;
        }

        .header-rojo {
            background-color: #B31919;
            height: 60px;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 30px;
        }

        .help-icon-img {
            height: 40px;
        }

        .blocked-card {
            background: white;
            width: 100%;
            max-width: 420px;
            padding: 50px 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            margin: auto;
            text-align: center;
        }

        .blocked-icon {
            height: 75px; 
            margin-bottom: 25px;
        }

        .blocked-title {
            font-weight: 700;
            font-size: 1.3rem;
            margin-bottom: 15px;
            color: #212529;
            line-height: 1.3;
        }

        .blocked-text {
            font-size: 0.85rem;
            color: #6c757d;
            line-height: 1.6;
            margin-bottom: 0;
        }

        .footer-standard {
            height: 80px;
            background-color: #fff;
            border-top: 1px solid #eee;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 0 40px;
            margin-top: auto;
        }

        .footer-img {
            height: 45px;
        }
    </style>
</head>
<body>

    <header class="header-rojo">
        <img src="~/img/ceplan.svg" alt="CEPLAN" style="height: 32px;">
        <a href="#"><img src="~/img/interrogacion.svg" class="help-icon-img" alt="Ayuda"></a>
    </header>

    <main class="container d-flex flex-column flex-grow-1 justify-content-center py-4">

        <div class="blocked-card">
            <img src="~/img/soporte.svg" class="blocked-icon" alt="Soporte Técnico">

            <div class="blocked-title">
                Cuenta bloqueada<br>temporalmente
            </div>

            <p class="blocked-text">
                Has excedido el número máximo de intentos fallidos (5). Por seguridad, tu cuenta ha sido bloqueada durante 15 minutos. Intenta nuevamente más tarde.
            </p>
        </div>

    </main>

    <footer class="footer-standard">
        <img src="~/img/footer.svg" class="footer-img" alt="Logos Institucionales">
    </footer>

</body>
</html>