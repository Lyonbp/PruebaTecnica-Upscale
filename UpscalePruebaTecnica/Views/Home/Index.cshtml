@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Activación de cuenta - CEPLAN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #f5f5f5;
            background-image: url('/img/inicio.png');
            background-repeat: no-repeat;
            background-position: bottom left;
            background-size: contain;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .header-rojo {
            background-color: #B31919;
            height: 60px;
            width: 100%;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 0 30px;
        }

        .help-icon-img { height: 40px; }

        .main-content {
            flex-grow: 1;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            z-index: 1;
            padding-top: 20px;
        }

        .activation-card {
            background: white;
            width: 100%;
            max-width: 400px;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            text-align: center;
            margin: 20px auto 0 auto
        }

        .rocket-img { width: 100px; margin-bottom: 25px; }

        .btn-iniciar {
            background-color: #0056b3;
            color: white;
            padding: 12px 60px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 500;
            display: inline-block;
            margin-top: 20px;
            transition: background 0.3s;
        }

        .btn-iniciar:hover {
            background-color: #004494;
            color: white;
        }

        .footer {
            height: 80px;
            background-color: #fff;
            border-top: 1px solid #eee;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 0 40px;
        }

        .footer-img { height: 45px; }
    </style>
</head>
<body>

    <header class="header-rojo">
        <a href="#"><img src="~/img/interrogacion.svg" class="help-icon-img" alt="Ayuda"></a>
    </header>

    <main class="main-content">
        <div class="activation-card">
            <img src="~/img/cohete.svg" class="rocket-img" alt="Éxito">

            <h2 class="fw-bold mb-4">¡Bienvenida, July!</h2>

            <p class="text-muted mb-1">Su cuenta en el aplicativo X está activada.</p>
            <p class="text-muted">Ya puede iniciar sesión.</p>

            <a href="@Url.Action("Index", "Login")" class="btn-iniciar">Iniciar sesión</a>
        </div>
    </main>

    <footer class="footer">
        <img src="~/img/footer.svg" class="footer-img" alt="Logos Institucionales">
    </footer>

</body>
</html>